generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  password    String
  phoneNumber String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  cars        Car[]
}

model Car {
  id               String   @id @default(cuid())
  brand            String
  model            String
  year             Int
  mileage          Int
  inspectionRating Int
  description      String?
  imageUrl         String?
  price            Int
  priceBreakdown   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}